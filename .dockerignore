# Version control
.git
.gitignore
.github

# Build artifacts — never bake stale outputs into the image
target/
frontend/node_modules/
frontend/dist/
**/*.bak

# Runtime data (must come from volumes, not the image)
data/
*.db
*.db-*
certs/

# Docs, tests, configs not needed at runtime
docs/
tests/
playwright-report/
test-results/

# Editor / OS noise
.vscode/
.idea/
.DS_Store

# Local secrets / env — pass via compose `environment`/`env_file` instead
.env
.env.docker
