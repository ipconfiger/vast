# =============================================================================
# Copy to `.env.docker` and edit. Compose loads it automatically (see
# docker-compose.yml `env_file`). Values here override the `environment:`
# defaults in docker-compose.yml.
#
# Generate a strong JWT secret:
#   openssl rand -base64 48
# =============================================================================

# ---- Secrets (change these!) -------------------------------------------------
JWT_SECRET=replace-with-output-of-openssl-rand-base64-48

# Admin console. Leave ADMIN_PASSWORD empty to disable the admin backend.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ---- Optional ----------------------------------------------------------------
INVITE_CODE=IM2024
TLS_MODE=none                # none | self-signed | lets-encrypt
SERVER_PORT=3000
UPLOAD_MAX_SIZE=52428800     # bytes (50 MiB)
RUST_LOG=info                # trace|debug|info|warn|error
DATABASE_URL=sqlite:vast.db
VAPID_SUBJECT=mailto:push@vast.local
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
