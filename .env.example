# ───────────────────────────────────────────────
# IM Server — Environment configuration
# Copy this file to .env and fill in secrets.
# ───────────────────────────────────────────────

# SQLite database path
DATABASE_URL=sqlite:vast.db

# JWT signing secret (generate with: openssl rand -base64 48)
JWT_SECRET=

# Invite code required on registration (leave empty to disable)
INVITE_CODE=

# HTTP listen port
SERVER_PORT=3000

# Max upload size in bytes (default 50 MiB)
UPLOAD_MAX_SIZE=52428800

# TLS mode: "none" for plain HTTP, "self-signed" or "letsencrypt"
TLS_MODE=none

# Admin console credentials.
# ADMIN_USERNAME defaults to "admin" when unset.
# Leave ADMIN_PASSWORD empty to disable the admin backend entirely;
# when set, the cleartext is hashed (argon2id) in-memory on startup and
# never persisted.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
